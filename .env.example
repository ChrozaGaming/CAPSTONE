# Copy ke .env dan isi sesuai instalasi PostgreSQL lokal kamu.
# .env tidak di-commit (lihat .gitignore).
#
# Bila .env tidak ada / koneksi PG gagal, server tetap jalan
# dalam mode JSON-only (graceful fallback). WebSocket tetap aktif.

PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
PG_DATABASE=capstone

PORT=3000

# ─── Auth (Phase 2) ──────────────────────────────────────────────────
# JWT_SECRET HARUS sama dengan VPS Next.js NEXTAUTH_SECRET supaya token
# yang di-issue oleh VPS bisa di-verify oleh local server.js.
# Untuk local development: pakai default placeholder.
# Untuk production: generate dengan `openssl rand -base64 48`
JWT_SECRET=dev-secret-change-in-production-min-32-char-please-rotate

# URL VPS Next.js untuk redirect saat user logout / token invalid.
# Phase 2 testing: kosongkan / set ke localhost:3001 (Next.js dev server).
VPS_LOGIN_URL=http://localhost:3001/login

# Mode dev — kalau true, /api/auth/dev-token endpoint aktif untuk
# testing tanpa harus jalanin Next.js. WAJIB false di production.
ALLOW_DEV_TOKEN=true
